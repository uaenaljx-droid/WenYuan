{
  "name": "persona-skill-planet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Three.js literary and philosophical persona atlas.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "prepare:cloudflare": "node scripts/prepare-cloudflare-dist.mjs",
    "deploy:cloudflare": "npm run prepare:cloudflare && npm exec --yes wrangler@latest -- pages deploy cloudflare-dist --project-name wenyuan --branch main",
    "validate:personas": "node scripts/validate-personas.mjs",
    "validate:routes": "node scripts/validate-routes.mjs",
    "validate:relations": "node scripts/validate-relations.mjs",
    "validate:themes": "node scripts/validate-themes.mjs",
    "validate:works": "node scripts/validate-works.mjs",
    "validate:copy": "node scripts/validate-copy.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "generate:search-index": "node scripts/generate-search-index.mjs",
    "generate:routes": "node scripts/generate-route-sequences.mjs",
    "generate:tour-path": "node scripts/generate-tour-path.mjs",
    "generate:gpt-profiles": "node scripts/generate-persona-profiles-with-gpt.mjs",
    "generate:gpt-works": "node scripts/generate-work-guides-with-gpt.mjs",
    "merge:gpt-content": "node scripts/merge-generated-content.mjs",
    "audit:content": "node scripts/audit-generated-content.mjs",
    "fetch:avatars": "node scripts/fetch-authentic-avatars.mjs",
    "screenshot:avatars": "node scripts/screenshot-authentic-avatars.mjs",
    "crop:avatars": "node scripts/crop-avatars.mjs",
    "generate:avatar-sizes": "node scripts/generate-avatar-sizes.mjs",
    "generate:avatar-manifest": "node scripts/generate-avatar-manifest.mjs",
    "generate:persona-index": "node scripts/generate-persona-index.mjs",
    "generate:stats": "node scripts/generate-persona-stats.mjs",
    "audit:avatars": "node scripts/audit-avatars.mjs",
    "normalize:avatars": "node scripts/normalize-avatars.mjs",
    "generate:fallback-avatars": "node scripts/generate-fallback-avatars.mjs",
    "data:seed500": "node scripts/seed-500-personas.mjs",
    "debug:geo": "node scripts/debug-geo.mjs",
    "data:expand": "node scripts/expand-atlas.mjs",
    "data:avatars": "node scripts/fetch-avatars.mjs",
    "data:works": "node scripts/fetch-works.mjs",
    "data:editorial": "node scripts/curate-editorial.mjs",
    "video:capture": "node scripts/capture-promo-clips.mjs",
    "video:preview": "set NAPI_RS_FORCE_WASI=1&& remotion studio src/video/index.ts",
    "video:render": "set NAPI_RS_FORCE_WASI=1&& remotion render src/video/index.ts WenyuanAtlasPromo60s dist/video/wenyuan-atlas-promo-60s.mp4",
    "video:render:vertical": "set NAPI_RS_FORCE_WASI=1&& remotion render src/video/index.ts WenyuanAtlasPromoVertical dist/video/wenyuan-atlas-promo-vertical-60s.mp4"
  },
  "dependencies": {
    "gsap": "^3.12.5",
    "three": "^0.165.0"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.484",
    "playwright": "^1.61.1",
    "puppeteer-core": "^25.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "^4.0.484",
    "sharp": "^0.35.3",
    "vite": "^8.1.3",
    "zod": "^4.3.6"
  }
}
